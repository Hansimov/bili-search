{
    "bili_data_root": "YOUR_BILI_DATA_ROOT",
    "ssl_key_file": "configs/key.pem",
    "ssl_cert_file": "configs/cert.pem",
    "elastic_pro": {
        "host": "localhost",
        "port": 9200,
        "ca_certs": "YOUR_ELASTIC_PRO_CA_CERT_PATH",
        "api_key": "YOUR_ELASTIC_PRO_API_KEY",
        "username": "elastic",
        "password": "YOUR_ELASTIC_PRO_PASSWORD"
    },
    "elastic_dev": {
        "endpoint": "https://localhost:19203",
        "host": "localhost",
        "port": 19203,
        "ca_certs": "YOUR_ELASTIC_DEV_CA_CERT_PATH",
        "api_key": "YOUR_ELASTIC_DEV_API_KEY",
        "username": "elastic",
        "password": "YOUR_ELASTIC_DEV_PASSWORD"
    },
    "mongo": {
        "host": "YOUR_MONGO_HOST",
        "port": 27017,
        "dbname": "YOUR_MONGO_DBNAME"
    },
    "tei_clients": {
        "endpoints": [
            "http://YOUR_TEI_HOST:28800"
        ]
    },
    "bili_store": {
        "endpoint": "http://YOUR_BILI_STORE_HOST:21501",
        "timeout": 30
    },
    "llms": {
        "deepseek": {
            "endpoint": "https://api.deepseek.com/chat/completions",
            "api_key": "YOUR_DEEPSEEK_API_KEY",
            "model": "deepseek-reasoner",
            "api_format": "openai",
            "tasks": []
        },
        "volcengine": {
            "endpoint": "https://ark.cn-beijing.volces.com/api/v3/chat/completions",
            "api_key": "YOUR_VOLCENGINE_API_KEY",
            "model": "YOUR_VOLCENGINE_MODEL_ID",
            "api_format": "openai",
            "tasks": []
        },
        "doubao-seed-2-0-mini": {
            "endpoint": "https://ark.cn-beijing.volces.com/api/v3/chat/completions",
            "api_key": "YOUR_VOLCENGINE_API_KEY",
            "model": "doubao-seed-2-0-mini-260215",
            "api_format": "openai",
            "tasks": []
        },
        "qwen2.5-coder-7b": {
            "endpoint": "https://api.siliconflow.cn/v1/chat/completions",
            "api_key": "YOUR_SILICONFLOW_API_KEY",
            "model": "Qwen/Qwen2.5-Coder-7B-Instruct",
            "api_format": "openai",
            "tasks": []
        },
        "qwen2-72b": {
            "endpoint": "https://api.siliconflow.cn/v1/chat/completions",
            "api_key": "YOUR_SILICONFLOW_API_KEY",
            "model": "Vendor-A/Qwen/Qwen2-72B-Instruct",
            "api_format": "openai",
            "tasks": []
        },
        "gemma2-9b": {
            "endpoint": "https://api.siliconflow.cn/v1/chat/completions",
            "api_key": "YOUR_SILICONFLOW_API_KEY",
            "model": "google/gemma-2-9b-it",
            "api_format": "openai",
            "tasks": []
        },
        "llama-3.1-8b": {
            "endpoint": "https://api.siliconflow.cn/v1/chat/completions",
            "api_key": "YOUR_SILICONFLOW_API_KEY",
            "model": "meta-llama/Meta-Llama-3.1-8B-Instruct",
