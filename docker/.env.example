# 复制本文件到 docker/.env 后再按需修改。
# 不敏感的默认值可以直接保留；敏感值请只写入本地文件，不要提交到仓库。

BILI_SEARCH_APP_HOST=0.0.0.0
BILI_SEARCH_APP_PORT=21001
BILI_SEARCH_APP_ELASTIC_INDEX=bili_videos_dev6
BILI_SEARCH_APP_ELASTIC_ENV_NAME=elastic_dev
BILI_SEARCH_APP_LLM_CONFIG=gpt

BILI_GOOGLE_HUB_BASE_URL=http://host.docker.internal:18100
BILI_GOOGLE_HUB_TIMEOUT=45
BILI_LLM_TIMEOUT=60

TZ=Asia/Shanghai

BSDK_BASE_IMAGE=bili-search-base:ubuntu24.04-py3
BSDK_PROJECT_NAME=bili-search-p21001
BSDK_SERVICE_NAME=bili-search
BSDK_CONTAINER_NAME=bili-search-p21001
BSDK_IMAGE=bili-search:p21001
BSDK_CONFIGS_DIR=./configs
BSDK_LOGS_DIR=./logs
BSDK_PIP_INDEX_URL=https://mirrors.ustc.edu.cn/pypi/simple
BSDK_PIP_EXTRA_INDEX_URL=https://pypi.org/simple
BSDK_PIP_TRUSTED_HOST=mirrors.ustc.edu.cn
BSDK_PIP_RETRIES=3
BSDK_PIP_TIMEOUT=60